# Copy this file to .env and fill in your own values.
#   cp .env.example .env
# .env is gitignored — never commit real keys.

# Google Gemini API key. Used by the realtime voice model, the post-call
# summary model, and the policy RAG embeddings.
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# LiveKit Cloud / self-hosted server connection details.
# Create a project at https://cloud.livekit.io to get these.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
